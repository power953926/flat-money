rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /houseFunds/default {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (
          !('editors' in resource.data)
          || resource.data.editors.keys().size() == 0
          || request.auth.token.email in resource.data.editors.keys()
        );
    }
  }
}
